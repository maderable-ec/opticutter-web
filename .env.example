# Base URL for API requests. Vite inlines this at BUILD time, so it cannot be
# changed once the image is built.
#
# Leave it EMPTY. httpClient.ts then falls back to '' and issues relative
# requests to /api/v1/..., which:
#   - in development, the Vite dev-server proxy forwards to the API on :8000
#   - in production, Caddy serves from the same origin (app.maderable.ec)
#
# Only set it to point the SPA at an API on a different origin, which also means
# enabling CORS on the backend.
VITE_API_BASE_URL=
